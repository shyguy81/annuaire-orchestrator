graph LR
    subgraph CICD["🔄 CI/CD Pipeline"]
        A["📝 Push Code<br/>git push → main"]
        B["⚙️ GitHub Actions"]
        C["🔨 Build<br/>docker build"]
        D["📦 Push Image<br/>ghcr.io"]
    end

    subgraph REGISTRY["🗃️ Image Registry"]
        REG["backend:latest"]
    end

    subgraph K8S["☸️ Kubernetes - Production"]
        PULL["🔄 Pull Latest"]
        DEPLOY["🚀 Deployment"]
        POD1["📦 Pod 1<br/>backend"]
        POD2["📦 Pod 2<br/>backend"]
        POD3["📦 Pod 3<br/>backend"]
        SVC["🔗 Service<br/>8000"]
        ING["🌐 Ingress<br/>TLS"]
    end

    subgraph CLIENT["💻 Client"]
        WS["🖥️ Workstation"]
    end

    A --> B --> C --> D
    D --> REG
    REG --> PULL
    PULL --> DEPLOY
    DEPLOY --> POD1
    DEPLOY --> POD2
    DEPLOY --> POD3
    POD1 --> SVC
    POD2 --> SVC
    POD3 --> SVC
    SVC --> ING
    ING <-->|HTTP/HTTPS<br/>backend.example.com| WS

